# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-long-random-secret-key

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://studytool:studytool_dev@localhost:5432/studytool

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URL=mongodb://studytool:studytool_dev@localhost:27017
MONGO_DB_NAME=studytool

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
